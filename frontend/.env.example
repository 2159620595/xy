# 可选：Vercel 部署且不填写时，会默认回退到 /_proxy
VITE_API_BASE_URL=
# 可选：不填时默认等于 VITE_API_BASE_URL
VITE_STATIC_BASE_URL=
# 可选：不填时默认自动拼接为 ${VITE_API_BASE_URL}/netdisk_api/api
VITE_NETDISK_API_BASE=
# 可选：不填时默认自动拼接为 ${VITE_API_BASE_URL}/netdisk_api/judian_api
VITE_JUDIAN_API_BASE=
VITE_JUDIAN_API_TIMEOUT_MS=30000
VITE_JUDIAN_LOGIN_API_TIMEOUT_MS=60000
# 可选：卡密“打开页面/导出访问卡密”使用的公网前台域名；不填时默认使用当前站点 origin
VITE_PUBLIC_REDEEM_ORIGIN=
